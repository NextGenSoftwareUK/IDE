# ── OASIS IDE Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# In development Electron loads .env automatically via process.env.

# ── Web4 / ONODE (avatar auth, karma, NFT, wallet, holon CRUD) ───────────────
OASIS_API_URL=http://localhost:7777

# ── Web6 WebAPI (AI completions, FAHRN, A2A tasks, memory, orchestrator) ─────
OASIS_WEB6_URL=http://localhost:64596
# Optional server-to-server pre-shared key (sent as X-Web6-Api-Key header).
# Leave blank if using JWT bearer auth from Web4 login instead.
OASIS_WEB6_API_KEY=

# ── Web7 WebAPI (collective consciousness, human-AI symbiosis) ───────────────
OASIS_WEB7_URL=http://localhost:62798

# ── Web8 WebAPI (distributed mesh routing, protocol bridge) ──────────────────
OASIS_WEB8_URL=http://localhost:65332

# ── Web9 WebAPI (singularity aggregation — polls Web4-Web8 health) ───────────
OASIS_WEB9_URL=http://localhost:65342

# ── Web10 WebAPI (source / root identity) ────────────────────────────────────
OASIS_WEB10_URL=http://localhost:57483

# ── MCP Server ────────────────────────────────────────────────────────────────
# Leave blank to auto-detect the Web6 MCP server project via dotnet run.
# Can be:
#   - A path to a .js file           → launched with node
#   - A path to an .exe / binary     → launched directly
#   - A path to a project directory  → launched with dotnet run --project
OASIS_MCP_SERVER_PATH=

# ── STAR CLI ──────────────────────────────────────────────────────────────────
# Path to the star.exe binary. Leave blank to use the default location in the
# OASIS2 monorepo: STAR ODK/NextGenSoftware.OASIS.STAR.CLI/bin/Debug/net10.0/star.exe
OASIS_STAR_CLI_PATH=

# ── AI / Agent Keys ───────────────────────────────────────────────────────────
# Required for Claude and OpenServ coding agent modes.
SERV_API_KEY=

# Optional — enables local LLM fallback chat (gpt-4o-mini).
OPENAI_API_KEY=

# ── IDE Behaviour ─────────────────────────────────────────────────────────────
# Override the default Web6 A2A agent used for IDE chat.
OASIS_IDE_ASSISTANT_AGENT_ID=oasis-ide-assistant
